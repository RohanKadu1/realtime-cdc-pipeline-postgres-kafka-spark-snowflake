# PostgreSQL Configuration
PG_HOST=localhost
PG_DB=your_database_name
PG_USER=your_postgres_user
PG_PASSWORD=your_postgres_password

# Kafka Configuration
KAFKA_SERVERS=localhost:9092
KAFKA_TOPIC=your_topic_name
REPLICATION_SLOT=your_slot_name

# Target table to capture CDC events from (format: schema.table)
TARGET_TABLE=public.users

# Snowflake Configuration
SF_URL=https://your_account.snowflakecomputing.com
SF_USER=your_snowflake_user
SF_PASSWORD=your_snowflake_password
SF_DATABASE=your_database
SF_SCHEMA=your_schema
SF_WAREHOUSE=your_warehouse
SF_ROLE=your_role
